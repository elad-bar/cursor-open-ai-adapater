{
  "name": "cursor-sdk-open-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:api": "tsx watch src/api/index.ts",
    "dev:client": "tsx src/client/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/api/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.23",
    "@hono/node-server": "^1.14.4",
    "hono": "^4.7.10",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "dotenv": "^17.4.2",
    "openai": "^6.48.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "optionalDependencies": {
    "@cursor/sdk-linux-x64": "1.0.23",
    "@cursor/sdk-win32-x64": "1.0.23"
  }
}
