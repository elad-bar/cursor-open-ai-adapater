HOST=0.0.0.0
PORT=8080

# Dev-only fallback when clients omit Authorization: Bearer (Archestra sends the Cursor key as OpenAI API key)
# CURSOR_API_KEY=cursor_...

# cloud (default) | local
CURSOR_RUNTIME=cloud

# Required for cloud runtime: comma-separated git repo URLs
# CURSOR_CLOUD_REPOS=https://github.com/org/repo

# Local runtime working directory (dev / mounted volume in Docker)
CURSOR_LOCAL_CWD=.

MODELS_CACHE_TTL_SECONDS=600
