HOST=0.0.0.0
PORT=8080

# Dev-only fallback when clients omit Authorization: Bearer
# CURSOR_API_KEY=cursor_...

MODELS_CACHE_TTL_SECONDS=600

# Optional streamable HTTP MCP gateway (URL from your MCP gateway provider)
# MCP_GATEWAY_URL=https://mcp.example.com/v1/mcp/my-gateway

# Per-request header for MCP gateway auth (when MCP_GATEWAY_URL is set)
# Clients send X-Mcp-Gateway-Token

# Streaming keepalive during long Cursor tool runs; 0 disables
# STREAM_IDLE_HEARTBEAT_SECONDS=30

# Agent session stickiness (OpenAI `user` field, or optional header below)
# AGENT_SESSION_TTL_SECONDS=3600
# AGENT_SESSION_MAX_ENTRIES=500
# AGENT_SESSION_HEADER=X-Custom-Session-Id
