HOST=0.0.0.0
PORT=8080

# Dev-only fallback when clients omit Authorization: Bearer (e.g. LLM proxy sends the Cursor key as OpenAI API key)
# CURSOR_API_KEY=cursor_...

MODELS_CACHE_TTL_SECONDS=600

# Optional streamable HTTP MCP gateway (URL from your MCP gateway provider)
# MCP_GATEWAY_URL=https://mcp.example.com/v1/mcp/my-gateway

# Streaming keepalive during long Cursor tool runs (Archestra response-progress); 0 disables
# STREAM_IDLE_HEARTBEAT_SECONDS=30
